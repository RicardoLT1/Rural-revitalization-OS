# Xiangyun OS local/demo environment example
#
# Copy this file to .env for local reference if you need shell-level variables.
# Current PowerShell startup scripts do not auto-load .env.
# Export variables in your terminal/session before starting services when overriding defaults.
# Do not commit real production secrets.

# Infrastructure
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=xiangyun_os
MYSQL_USER=xiangyun_app
MYSQL_PASSWORD=change-me-app-password
MYSQL_URL=jdbc:mysql://127.0.0.1:3307/xiangyun_os?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=xiangyun
RABBITMQ_PASSWORD=change-me-rabbitmq-password

NACOS_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public

# Security
JWT_SECRET=change-me-strong-jwt-secret
JWT_TTL_SECONDS=7200
XIANGYUN_INTERNAL_AUTH_ENABLED=true
XIANGYUN_INTERNAL_SECRET=change-me-strong-internal-secret
XIANGYUN_INTERNAL_TTL_SECONDS=60
XIANGYUN_INTERNAL_CLOCK_SKEW_SECONDS=5

# Business defaults
REPORT_DEFAULT_RANGE_DAYS=7
RISK_WARNING_THRESHOLD=3
DASHBOARD_CACHE_TTL_SECONDS=180
RESOURCE_DETAIL_CACHE_TTL_SECONDS=600
OUTBOX_INITIAL_DELAY_MS=10000
OUTBOX_SCAN_DELAY_MS=5000

# Mini program local API entry
MINIPROGRAM_BASE_URL=http://127.0.0.1:8080/api
