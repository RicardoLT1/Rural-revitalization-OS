<view class="page-root">
  <section-header title="Trend Forecast" subtitle="Forecast + confidence + strategy" />

  <view class="page-section">
    <chart-card title="Visitor Time-Series Forecast" ecOption="{{forecastOption}}" />
  </view>

  <view class="page-section card band-box">
    <view class="title">Confidence Band</view>
    <view class="confidence">Confidence: {{band.confidence}}</view>
    <view class="range">{{band.range}}</view>
  </view>

  <view class="page-section">
    <section-header title="Risk Alerts" />
    <risk-alert-card wx:for="{{risks}}" wx:key="id" risk="{{item}}" />
  </view>

  <view class="page-section card strategy-box">
    <section-header title="AI Strategies" />
    <view wx:for="{{strategies}}" wx:key="*this" class="strategy-item">{{index + 1}}. {{item}}</view>
  </view>
</view>