<view class="page-root">
  <section-header title="Resource Map" subtitle="Visible, searchable, investable" />
  <filter-bar options="{{tagOptions}}" activeKey="{{activeTag}}" bind:change="onTagChange" />

  <view class="map-wrap page-section">
    <map
      id="resourceMap"
      class="map"
      latitude="{{mapCenter.latitude}}"
      longitude="{{mapCenter.longitude}}"
      scale="14"
      markers="{{markers}}"
      bindmarkertap="onMarkerTap"
      show-location="true"
      enable-3D="true"
      enable-poi="true"
    ></map>
  </view>

  <view wx:if="{{selectedResource.id}}" class="popup-wrap">
    <map-resource-popup resource="{{selectedResource}}" bind:tap="onPopupTap" />
  </view>

  <view class="page-section">
    <section-header title="Resource List" subtitle="Tap a card for details" />
    <empty-state wx:if="{{!filteredResources.length}}" title="No resources in this filter" description="Try another tag" />
    <resource-card
      wx:for="{{filteredResources}}"
      wx:key="id"
      resource="{{item}}"
      showActions="{{false}}"
      bind:tap="onResourceTap"
    />
  </view>
</view>