<loading-state wx:if="{{pageState === 'loading'}}" text="{{loadingText}}" />
<error-state wx:elif="{{pageState === 'error'}}" title="{{errorTitle}}" message="{{errorMessage}}" bind:retry="onRetry" />
<block wx:else>
  <view class="page-root resource-page">
    <section-header title="资源列表" subtitle="搜索可合作资源，查看详情后提交申请" />

    <view class="search-card">
      <view class="search-row">
        <input class="search-input" placeholder="搜索资源名称或位置" value="{{keyword}}" confirm-type="search" bindinput="onKeywordInput" bindconfirm="onSearch" />
        <button class="search-btn" bindtap="onSearch">搜索</button>
      </view>
      <view class="filter-line">
        <view wx:for="{{categoryOptions}}" wx:key="*this" data-value="{{item}}" class="filter-chip {{activeCategory === item ? 'active' : ''}}" bindtap="onCategoryTap">{{item}}</view>
      </view>
      <view class="filter-line compact">
        <view wx:for="{{statusOptions}}" wx:key="*this" data-value="{{item}}" class="filter-chip {{activeStatus === item ? 'active' : ''}}" bindtap="onStatusTap">{{item}}</view>
      </view>
    </view>

    <view class="map-wrap" wx:if="{{markers.length}}">
      <map class="map" latitude="{{mapCenter.latitude}}" longitude="{{mapCenter.longitude}}" scale="13" markers="{{markers}}"></map>
    </view>

    <empty-state wx:if="{{pageState === 'empty'}}" title="{{emptyTitle}}" description="{{emptyDescription}}" />

    <view class="resource-list" wx:else>
      <view wx:for="{{resources}}" wx:key="id" class="resource-card" data-id="{{item.id}}" bindtap="onResourceTap">
        <view class="card-main">
          <view class="resource-title">{{item.name}}</view>
          <view class="resource-meta">{{item.category}} · {{item.address}}</view>
          <view class="resource-desc">面积 {{item.area}}㎡ · 预计年收益 {{item.annualEstimate}} 万元</view>
        </view>
        <view class="status-pill">{{item.investmentStatus}}</view>
      </view>
      <view class="load-more" wx:if="{{isLoadingMore}}">正在加载更多</view>
      <view class="load-more" wx:elif="{{!hasMore && resources.length}}">已加载全部资源</view>
    </view>
  </view>
</block>
