<view class="page-root" wx:if="{{detail.id}}">
  <image class="cover card" src="{{detail.cover}}" mode="aspectFill"></image>

  <view class="page-section card info-card">
    <view class="row-between">
      <view class="name">{{detail.name}}</view>
      <status-badge text="{{detail.investmentStatus}}" type="{{statusType}}" />
    </view>
    <view class="meta">{{detail.category}} | {{detail.area}} m2 | {{detail.address}}</view>
    <view class="intro">{{detail.intro}}</view>
    <tag-group tags="{{detail.tags}}" />
  </view>

  <view class="page-section card info-card">
    <section-header title="Business Metrics" />
    <view class="kpi-grid">
      <view class="kpi-item">
        <view class="label">Annual Estimate</view>
        <view class="value mono">{{detail.annualEstimate}}</view>
      </view>
      <view class="kpi-item">
        <view class="label">Occupancy</view>
        <view class="value mono">{{detail.occupancyRate}}%</view>
      </view>
      <view class="kpi-item">
        <view class="label">Expected ROI</view>
        <view class="value mono">{{detail.expectedROI}}%</view>
      </view>
    </view>
  </view>

  <view class="page-section card info-card">
    <section-header title="Related Projects" />
    <view wx:for="{{detail.relatedProjects}}" wx:key="*this" class="project">{{item}}</view>
    <view class="contact">Owner: {{detail.owner}}</view>
    <view class="contact">Contact: {{detail.contact}}</view>
  </view>

  <view class="page-section actions">
    <view class="btn primary" bindtap="onGoMatch">View Match</view>
    <view class="btn ghost" bindtap="onMockAction" data-name="Start Transfer">Start Transfer</view>
    <view class="btn ghost" bindtap="onMockAction" data-name="Contact">Contact</view>
  </view>
</view>