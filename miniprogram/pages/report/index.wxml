<view class="page-root">
  <section-header title="Smart Report" subtitle="Auto analytics and suggestions" />

  <view class="summary-grid page-section">
    <view wx:for="{{summary}}" wx:key="id" class="summary-card">
      <view class="title">{{item.title}}</view>
      <view class="value mono">{{item.value}}</view>
      <view class="delta">{{item.delta}}</view>
    </view>
  </view>

  <view class="page-section">
    <chart-card
      title="Visitor Trend Line"
      periods="{{periods}}"
      activePeriod="{{period}}"
      ecOption="{{lineOption}}"
      bind:periodchange="onPeriodChange"
    />
  </view>

  <view class="page-section">
    <chart-card title="Revenue Bar" ecOption="{{barOption}}" />
  </view>

  <view class="page-section">
    <chart-card title="Revenue Ratio" ecOption="{{ringOption}}" />
  </view>

  <view class="page-section card summary-box">
    <section-header title="Auto Summary" />
    <view class="text">{{autoSummary}}</view>
  </view>

  <view class="page-section">
    <section-header title="AI Tips" />
    <ai-tip-card wx:for="{{aiTips}}" wx:key="id" tip="{{item}}" bind:action="onTipAction" />
  </view>

  <view class="page-section quick-actions">
    <view class="btn" data-action="match" bindtap="onQuickTap">Investment Match</view>
    <view class="btn" data-action="forecast" bindtap="onQuickTap">Trend Forecast</view>
  </view>
</view>