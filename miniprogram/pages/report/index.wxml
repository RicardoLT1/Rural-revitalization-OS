<loading-state wx:if="{{pageState === 'loading'}}" text="{{loadingText}}" />
<error-state wx:elif="{{pageState === 'error'}}" title="{{errorTitle}}" message="{{errorMessage}}" bind:retry="onRetry" />
<empty-state wx:elif="{{pageState === 'empty'}}" title="{{emptyTitle}}" description="{{emptyDescription}}" />
<block wx:else>
  <view class="page-root report-page">
    <section-header title="智能报表" subtitle="申请趋势、资源结构与运营建议" />

    <view class="summary-grid page-section">
      <view wx:for="{{summary}}" wx:key="id" class="summary-card">
        <view class="title">{{item.title}}</view>
        <view class="value mono">{{item.value}}</view>
        <view class="delta">{{item.delta}}</view>
      </view>
    </view>

    <view class="page-section">
      <chart-card
        title="申请趋势"
        periods="{{periods}}"
        activePeriod="{{period}}"
        ecOption="{{lineOption}}"
        bind:periodchange="onPeriodChange"
      />
    </view>

    <view class="page-section">
      <chart-card title="资源热度对比" ecOption="{{barOption}}" />
    </view>

    <view class="page-section">
      <chart-card title="资源类型结构" ecOption="{{ringOption}}" />
    </view>

    <view class="page-section card summary-box">
      <section-header title="自动摘要" />
      <view class="text">{{autoSummary}}</view>
    </view>

    <view class="page-section">
      <section-header title="智能建议" />
      <ai-tip-card wx:for="{{aiTips}}" wx:key="id" tip="{{item}}" bind:action="onTipAction" />
    </view>

    <view class="page-section quick-actions">
      <view class="btn" data-action="match" bindtap="onQuickTap">
        <text class="btn-icon">招</text> 招商推荐
      </view>
      <view class="btn" data-action="forecast" bindtap="onQuickTap">
        <text class="btn-icon">趋</text> 趋势预测
      </view>
    </view>
  </view>
</block>