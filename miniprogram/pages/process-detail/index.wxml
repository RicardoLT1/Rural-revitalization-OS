<view class="page-root" wx:if="{{detail.id}}">
  <view class="card head">
    <view class="row-between">
      <view class="title">{{detail.title}}</view>
      <status-badge text="{{detail.status}}" type="{{statusType}}" />
    </view>
    <view wx:if="{{detail.blocker}}" class="blocker">Blocker: {{detail.blocker}}</view>
  </view>

  <view class="page-section">
    <section-header title="Workflow Overview" />
    <workflow-node-strip nodes="{{detail.nodes}}" currentNodeId="{{detail.currentNodeId}}" bind:nodetap="onNodeTap" />
  </view>

  <view class="page-section">
    <section-header title="Timeline" subtitle="Expand or collapse remarks" />
    <timeline-node
      wx:for="{{detail.nodes}}"
      wx:key="id"
      node="{{item}}"
      expanded="{{expandedNodeId === item.id}}"
      bind:toggle="onNodeToggle"
    />
  </view>

  <view class="page-section card records">
    <section-header title="Process Records" />
    <filter-bar options="{{recordFilters}}" activeKey="{{recordFilter}}" bind:change="onRecordFilterChange" />
    <view wx:for="{{visibleRecords}}" wx:key="id" class="record-item">
      <view class="row-between">
        <view class="action">{{item.action}}</view>
        <view class="time">{{item.time}}</view>
      </view>
      <view class="meta">{{item.operator}} | {{item.remark}}</view>
    </view>
  </view>

  <view class="page-section card archive">
    <section-header title="Archive" />
    <view class="line">Code: {{detail.archive.code}}</view>
    <view class="line">Archived At: {{detail.archive.archivedAt}}</view>
    <view class="line">Note: {{detail.archive.note}}</view>
  </view>
</view>