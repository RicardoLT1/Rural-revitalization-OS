<view class="page-root" wx:if="{{resource.id}}">
  <section-header title="Investment Match" subtitle="Score + reason + priority" />

  <resource-card resource="{{resource}}" showActions="{{false}}" bind:tap="onResourceTap" />

  <view class="page-section">
    <section-header title="Candidates" subtitle="Higher score, higher priority" />
    <empty-state wx:if="{{!matches.length}}" title="No candidate" />

    <view wx:for="{{matches}}" wx:key="id" class="match-card card">
      <view class="row-between">
        <view class="name">{{item.investor}}</view>
        <view class="score mono">{{item.score}}</view>
      </view>
      <view class="meta">Direction: {{item.direction}}</view>
      <view class="reason">{{item.reason}}</view>
      <status-badge text="{{item.priority}}" type="{{item.priorityType}}" size="small" />
    </view>
  </view>

  <view class="page-section">
    <section-header title="AI Summary" />
    <ai-tip-card tip="{{aiSummary}}" bind:action="onAiAction" />
  </view>
</view>