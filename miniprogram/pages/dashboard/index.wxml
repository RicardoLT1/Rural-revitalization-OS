<view class="page-root dashboard-page">
  <view class="hero card">
    <view class="role">{{roleName}} | {{villageName}}</view>
    <view class="headline">Village Operations Cockpit</view>
    <view class="sub">Flow, revenue, progress and risks in one place with AI suggestions</view>
  </view>

  <view class="stats-grid page-section">
    <stat-card
      wx:for="{{stats}}"
      wx:key="key"
      title="{{item.title}}"
      value="{{item.value}}"
      unit="{{item.unit}}"
      delta="{{item.delta}}"
      trend="{{item.trend}}"
      status="{{item.status}}"
      icon="{{item.icon}}"
    />
  </view>

  <view class="page-section">
    <section-header title="Visitor Trend" subtitle="7d / 30d" />
    <chart-card
      title="Visitor Line"
      periods="{{periods}}"
      activePeriod="{{trendPeriod}}"
      ecOption="{{trendOption}}"
      bind:periodchange="onTrendPeriodChange"
    />
  </view>

  <view class="page-section">
    <section-header title="Risk Alerts" subtitle="Key risks to follow" />
    <risk-alert-card wx:for="{{risks}}" wx:key="id" risk="{{item}}" />
  </view>

  <view class="page-section">
    <section-header title="AI Suggestions" subtitle="Auto-generated insights" />
    <ai-tip-card wx:for="{{suggestions}}" wx:key="id" tip="{{item}}" bind:action="onTipAction" />
  </view>

  <view class="page-section">
    <section-header title="Quick Entry" subtitle="Jump to core modules" />
    <view class="entry-grid">
      <view class="entry" data-action="map" bindtap="onEntryTap">Resource Map</view>
      <view class="entry" data-action="collab" bindtap="onEntryTap">Collab Desk</view>
      <view class="entry" data-action="report" bindtap="onEntryTap">Smart Report</view>
      <view class="entry" data-action="match" bindtap="onEntryTap">Match</view>
      <view class="entry" data-action="forecast" bindtap="onEntryTap">Forecast</view>
    </view>
  </view>
</view>