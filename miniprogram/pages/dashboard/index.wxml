<loading-state wx:if="{{pageState === 'loading'}}" text="{{loadingText}}" />
<error-state wx:elif="{{pageState === 'error'}}" title="{{errorTitle}}" message="{{errorMessage}}" bind:retry="onRetry" />
<empty-state wx:elif="{{pageState === 'empty'}}" title="{{emptyTitle}}" description="{{emptyDescription}}" />
<block wx:else>
  <view class="page-root dashboard-page {{contentReady ? 'content-ready' : ''}}">
    <view class="top-greeting reveal-block reveal-1">
      <view>
        <view class="brand-row">
          <view class="brand-logo">乡</view>
          <view>
            <view class="brand-name">乡耘 OS</view>
            <view class="brand-sub">资源服务</view>
          </view>
        </view>
        <view class="hello">您好，欢迎来到{{villageName || '青禾示范村'}}</view>
      </view>
      <view class="weather-pill">今日可逛</view>
    </view>

    <view wx:if="{{showDataHealth}}" class="data-health {{cacheStatusClass}} reveal-block reveal-2">
      <view class="health-main">
        <text class="health-dot"></text>
        <text>{{cacheStatusText}}</text>
      </view>
      <view class="health-meta">{{dataStaleText}} · {{dataRangeLabel}} · {{dataGeneratedAt}}</view>
    </view>

    <view class="hero-carousel reveal-block reveal-2">
      <swiper
        class="hero-swiper"
        autoplay="true"
        circular="true"
        interval="3600"
        duration="520"
        current="{{activeHeroIndex}}"
        bindchange="onHeroChange"
      >
        <swiper-item wx:for="{{heroSlides}}" wx:key="title">
          <view class="hero-card {{item.tone}}">
            <image class="hero-photo" src="{{item.image}}" mode="aspectFill" />
            <view class="hero-shade"></view>
            <view class="hero-copy">
              <view class="hero-kicker">{{item.kicker}}</view>
              <view class="hero-title">{{item.title}}</view>
              <view class="hero-text">{{item.text}}</view>
              <button class="hero-btn" data-action="{{item.action}}" bindtap="onEntryTap">{{item.button}} <text>→</text></button>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <view class="hero-dots">
        <text wx:for="{{heroSlides}}" wx:key="title" class="{{activeHeroIndex === index ? 'active' : ''}}"></text>
      </view>
    </view>

    <view class="metric-grid reveal-block reveal-3">
      <view class="metric-card" wx:for="{{homeMetrics}}" wx:key="title" data-action="{{item.action}}" bindtap="onEntryTap">
        <view class="metric-icon {{item.tone}}"><image src="{{item.icon}}" mode="aspectFit" /></view>
        <view class="metric-title">{{item.title}}</view>
        <view class="metric-value"><text>{{item.value}}</text>{{item.unit}}</view>
        <view class="metric-note">{{item.note}}</view>
      </view>
    </view>

    <view class="page-section reveal-block reveal-4">
      <view class="section-head">
        <view class="section-title">推荐资源</view>
        <view class="section-action" data-action="map" bindtap="onEntryTap">更多推荐</view>
      </view>
      <scroll-view class="recommend-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="recommend-grid">
        <view class="recommend-card" data-action="map" bindtap="onEntryTap">
          <image class="resource-photo" src="/assets/images/rice-terraces.jpg" mode="aspectFill" />
          <view class="resource-location">青禾村 · 距离 1.2km</view>
          <view class="recommend-body">
            <view class="recommend-title">青禾民宿改造项目</view>
            <view class="tag">高匹配</view>
            <view class="recommend-meta">青禾村 · 距离 1.2km</view>
            <view class="recommend-link">查看详情</view>
          </view>
        </view>
        <view class="recommend-card" data-action="map" bindtap="onEntryTap">
          <image class="resource-photo" src="/assets/images/rural-village.jpg" mode="aspectFill" />
          <view class="resource-location">文创村 · 距离 2.6km</view>
          <view class="recommend-body">
            <view class="recommend-title">乡村文创体验空间</view>
            <view class="tag good">优质</view>
            <view class="recommend-meta">适合内容共创、活动运营</view>
            <view class="recommend-link">查看详情</view>
          </view>
        </view>
      </view>
      </scroll-view>
    </view>

    <view class="page-section progress-card reveal-block reveal-5">
      <view class="section-head">
        <view class="section-title">我的申请进度</view>
        <view class="section-action" data-action="collab" bindtap="onEntryTap">全部申请</view>
      </view>
      <view class="progress-list" wx:if="{{recentApplications.length}}">
        <view class="progress-item" wx:for="{{recentApplications}}" wx:key="id" data-action="collab" bindtap="onEntryTap">
          <view class="node {{item.statusClass}}">单</view>
          <view class="progress-main">
            <view class="progress-title">{{item.title}}</view>
            <view class="progress-time">提交时间：{{item.createdAt}}</view>
          </view>
          <view class="progress-ring" style="background: conic-gradient(#fff 0 {{item.progress}}%, rgba(255,255,255,.25) {{item.progress}}%);"><view>{{item.progress}}%</view></view><view class="state {{item.statusClass}}">{{item.statusText}}</view><view class="progress-arrow">›</view>
        </view>
      </view>
      <view class="progress-empty" wx:else>
        <view class="empty-title">暂无合作申请</view>
        <view class="empty-desc">在资源详情页提交申请后，可在这里查看最新进度。</view>
      </view>
    </view>

    <view class="page-section quick-section reveal-block reveal-6">
      <view class="section-head">
        <view class="section-title">快捷入口</view>
      </view>
      <view class="quick-grid">
        <view class="quick-item" data-action="map" bindtap="onEntryTap"><view><image src="/assets/tabbar/map-active.png" /></view><text>资源地图</text></view>
        <view class="quick-item" data-action="collab" bindtap="onEntryTap"><view><image src="/assets/tabbar/apply-active.png" /></view><text>申请进度</text></view>
        <view class="quick-item" data-action="report" bindtap="onEntryTap"><view><image src="/assets/tabbar/report-active.png" /></view><text>智能报表</text></view>
        <view class="quick-item" data-action="match" bindtap="onEntryTap"><view><image src="/assets/tabbar/home-active.png" /></view><text>招商匹配</text></view>
      </view>
    </view>
  </view>
</block>
