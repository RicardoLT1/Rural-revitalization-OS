<loading-state wx:if="{{pageState === 'loading'}}" text="{{loadingText}}" />
<error-state wx:elif="{{pageState === 'error'}}" title="{{errorTitle}}" message="{{errorMessage}}" bind:retry="onRetry" />
<empty-state wx:elif="{{pageState === 'empty'}}" title="{{emptyTitle}}" description="{{emptyDescription}}" />
<block wx:else>
  <view class="page-root dashboard-page">
    <view class="hero card">
      <view class="role">{{roleName}} · {{villageName}}</view>
      <view class="headline">乡村运营驾驶舱</view>
      <view class="sub">聚合资源、申请、审批和运营趋势，帮助工作人员快速判断业务状态。</view>
    </view>

    <view class="stats-grid page-section">
      <stat-card
        wx:for="{{stats}}"
        wx:key="key"
        title="{{item.title}}"
        value="{{item.value}}"
        unit="{{item.unit}}"
        delta="{{item.delta}}"
        trend="{{item.trend}}"
        status="{{item.status}}"
        icon="{{item.icon}}"
      />
    </view>

    <view class="page-section">
      <section-header title="运营趋势" subtitle="近 7 天 / 近 30 天" />
      <chart-card
        title="申请趋势"
        periods="{{periods}}"
        activePeriod="{{trendPeriod}}"
        ecOption="{{trendOption}}"
        bind:periodchange="onTrendPeriodChange"
      />
    </view>

    <view class="page-section">
      <section-header title="风险预警" subtitle="临近超时和待处理事项" />
      <risk-alert-card wx:for="{{risks}}" wx:key="id" risk="{{item}}" />
    </view>

    <view class="page-section">
      <section-header title="智能建议" subtitle="根据资源与审批数据生成" />
      <ai-tip-card wx:for="{{suggestions}}" wx:key="id" tip="{{item}}" bind:action="onTipAction" />
    </view>

    <view class="page-section">
      <section-header title="快捷入口" subtitle="常用业务一键进入" />
      <view class="entry-grid">
        <view class="entry" data-action="map" bindtap="onEntryTap">
          <view class="entry-icon">源</view>
          <view class="entry-text">资源列表</view>
        </view>
        <view class="entry" data-action="collab" bindtap="onEntryTap">
          <view class="entry-icon">审</view>
          <view class="entry-text">我的申请</view>
        </view>
        <view class="entry" data-action="report" bindtap="onEntryTap">
          <view class="entry-icon">报</view>
          <view class="entry-text">智能报表</view>
        </view>
        <view class="entry" data-action="match" bindtap="onEntryTap">
          <view class="entry-icon">招</view>
          <view class="entry-text">招商推荐</view>
        </view>
        <view class="entry" data-action="forecast" bindtap="onEntryTap">
          <view class="entry-icon">趋</view>
          <view class="entry-text">趋势预测</view>
        </view>
      </view>
    </view>
  </view>
</block>