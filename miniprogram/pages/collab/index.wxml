<view class="page-root">
  <view class="todo-overview card">
    <view class="row-between">
      <view class="count">
        <view class="value mono">{{todoStats.total}}</view>
        <view class="label">Today To-do</view>
      </view>
      <view class="count warning">
        <view class="value mono">{{todoStats.urgent}}</view>
        <view class="label">Urgent</view>
      </view>
      <view class="count success">
        <view class="value mono">{{todoStats.completedToday}}</view>
        <view class="label">Done Today</view>
      </view>
    </view>
  </view>

  <view class="page-section">
    <section-header title="Category" subtitle="Filter to-do items" />
    <filter-bar options="{{categoryOptions}}" activeKey="{{activeCategory}}" bind:change="onCategoryChange" />
  </view>

  <view class="page-section">
    <section-header title="To-do List" subtitle="Tap to open process" />
    <empty-state wx:if="{{!filteredTodos.length}}" title="No to-do item" />
    <view wx:for="{{filteredTodos}}" wx:key="id" class="todo-card" data-processid="{{item.processId}}" bindtap="onTodoTap">
      <view class="row-between">
        <view class="title">{{item.title}}</view>
        <view class="status {{item.statusClass}}">{{item.status}}</view>
      </view>
      <view class="meta">Due: {{item.dueDate}} | Category: {{item.category}}</view>
    </view>
  </view>

  <view class="page-section">
    <section-header title="Approvals" subtitle="Demo actions: pass/reject" />
    <approval-card wx:for="{{approvals}}" wx:key="id" approval="{{item}}" bind:tap="onApprovalTap" bind:approve="onApprovalAction" />
  </view>

  <view class="page-section">
    <section-header title="Workflow Strip" subtitle="Node overview" />
    <workflow-node-strip nodes="{{workflowStrip}}" currentNodeId="{{workflowStripCurrent}}" bind:nodetap="onNodeTap" />
  </view>

  <view class="page-section">
    <section-header title="Messages" subtitle="Process-driven notices" />
    <message-item
      wx:for="{{messages}}"
      wx:key="id"
      messageId="{{item.processId}}"
      title="{{item.title}}"
      time="{{item.time}}"
      type="{{item.level}}"
      bind:tap="onMessageTap"
    />
  </view>

  <view class="page-section card archive">
    <view class="section-title">Archive Center</view>
    <view class="section-subtitle">Traceability for completed processes</view>
    <view class="quick-grid">
      <view class="quick">Project</view>
      <view class="quick">Asset</view>
      <view class="quick">Event</view>
      <view class="quick">Community</view>
    </view>
  </view>
</view>