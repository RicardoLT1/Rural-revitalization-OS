<view class="page-root">
  <view class="todo-overview card">
    <view class="row-between">
      <view class="count">
        <view class="value mono">{{todoStats.total}}</view>
        <view class="label">🗂 今日待办</view>
      </view>
      <view class="count warning">
        <view class="value mono">{{todoStats.urgent}}</view>
        <view class="label">⚠️ 紧急事项</view>
      </view>
      <view class="count success">
        <view class="value mono">{{todoStats.completedToday}}</view>
        <view class="label">✅ 今日完成</view>
      </view>
    </view>
  </view>

  <view class="page-section">
    <section-header title="事项分类" subtitle="切换分类同步更新列表" />
    <filter-bar options="{{categoryOptions}}" activeKey="{{activeCategory}}" bind:change="onCategoryChange" />
  </view>

  <view class="page-section">
    <section-header title="待办事项" subtitle="点击进入流程详情" />
    <empty-state wx:if="{{!filteredTodos.length}}" title="当前分类暂无待办" />
    <view wx:for="{{filteredTodos}}" wx:key="id" class="todo-card" data-processid="{{item.processId}}" bindtap="onTodoTap">
      <view class="row-between">
        <view class="title">{{item.title}}</view>
        <view class="status {{item.statusClass}}">{{item.status}}</view>
      </view>
      <view class="meta">截止：{{item.dueDate}} | 分类：{{item.category}}</view>
    </view>
  </view>

  <view class="page-section">
    <section-header title="审批事项" subtitle="可执行通过/驳回操作" />
    <approval-card wx:for="{{approvals}}" wx:key="id" approval="{{item}}" bind:tap="onApprovalTap" bind:approve="onApprovalAction" />
  </view>

  <view class="page-section">
    <section-header title="流程节点概览" subtitle="流程执行状态一目了然" />
    <workflow-node-strip nodes="{{workflowStrip}}" currentNodeId="{{workflowStripCurrent}}" bind:nodetap="onNodeTap" />
  </view>

  <view class="page-section">
    <section-header title="消息提醒" subtitle="流程驱动消息通知" />
    <message-item
      wx:for="{{messages}}"
      wx:key="id"
      messageId="{{item.processId}}"
      title="{{item.title}}"
      time="{{item.time}}"
      type="{{item.level}}"
      bind:tap="onMessageTap"
    />
  </view>

  <view class="page-section card archive">
    <view class="section-title">归档留痕中心</view>
    <view class="section-subtitle">流程完成后自动沉淀可追溯档案记录</view>
    <view class="quick-grid">
      <view class="quick">📝 项目申报</view>
      <view class="quick">🏘 资产流转</view>
      <view class="quick">🎪 活动筹备</view>
      <view class="quick">👥 村民议事</view>
    </view>
  </view>
</view>
