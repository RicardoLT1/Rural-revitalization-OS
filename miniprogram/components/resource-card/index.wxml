<view class="resource-card {{active ? 'active' : ''}}" bindtap="onTap">
  <view class="cover cover-{{coverClass}}">
    <view class="cover-mask"></view>
    <view class="cover-decor decor-1"></view>
    <view class="cover-decor decor-2"></view>

    <view class="cover-content">
      <view class="cover-top row-between">
        <view class="cover-type">{{resource.category}}</view>
        <view class="cover-state">{{resource.investmentStatus}}</view>
      </view>

      <view class="cover-bottom">
        <view class="cover-name">{{resource.name}}</view>
        <view class="cover-desc">{{coverDesc}}</view>
      </view>
    </view>
  </view>

  <view class="body">
    <view class="meta">面积 {{resource.area}} ㎡ | 预估年收益 {{resource.annualEstimate}} 万元</view>
    <view class="address">{{resource.address}}</view>
    <tag-group tags="{{resource.tags}}" />

    <view wx:if="{{showActions}}" class="actions">
      <view class="btn ghost" catchtap="onAction" data-action="detail">查看详情</view>
      <view class="btn primary" catchtap="onAction" data-action="match">查看推荐</view>
    </view>
  </view>
</view>