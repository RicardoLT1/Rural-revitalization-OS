<view class="timeline-node">
  <view class="line"></view>
  <view class="dot {{node.status}}"></view>
  <view class="content" bindtap="onToggle">
    <view class="row-between">
      <view class="name">{{node.name}}</view>
      <status-badge text="{{statusText}}" type="{{badgeType}}" size="small" />
    </view>
    <view class="meta">负责人：{{node.owner}} · {{node.time}}</view>
    <view wx:if="{{expanded}}" class="remark">{{node.remark}}</view>
  </view>
</view>
