<scroll-view class="filter-bar" scroll-x="true" show-scrollbar="false">
  <view class="inner">
    <view
      wx:for="{{options}}"
      wx:key="key"
      class="chip {{item.key === activeKey ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSelect"
    >
      {{item.label}}
    </view>
  </view>
</scroll-view>
