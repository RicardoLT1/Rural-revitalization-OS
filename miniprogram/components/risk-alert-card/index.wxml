<view class="risk-card" bindtap="onTap">
  <view class="row-between">
    <view class="title">{{risk.title}}</view>
    <status-badge text="{{levelText}}" type="{{badgeType}}" size="small" />
  </view>
  <view class="desc">{{risk.detail}}</view>
  <view class="assignee">责任小组：{{risk.assignee}}</view>
</view>
