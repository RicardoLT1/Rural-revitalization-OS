<view class="chart-card">
  <view class="header row-between">
    <view class="title">{{title}}</view>
    <view wx:if="{{periods && periods.length}}" class="periods">
      <view
        wx:for="{{periods}}"
        wx:key="key"
        class="period {{item.key === activePeriod ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onPeriodTap"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="line-chart" wx:if="{{kind === 'line' || kind === 'forecast'}}">
    <canvas
      id="{{lineCanvasId}}"
      canvas-id="{{lineCanvasId}}"
      class="line-canvas"
      width="{{canvasWidth}}"
      height="{{canvasHeight}}"
    ></canvas>
    <view class="x-axis">
      <view wx:for="{{lineLabels}}" wx:key="index" class="x-label">{{item}}</view>
    </view>
  </view>

  <view class="bar-chart" wx:if="{{kind === 'bar'}}">
    <view wx:for="{{barData}}" wx:key="index" class="bar-wrap">
      <view class="bar-shell">
        <view class="bar" style="height: {{item.height}}%;"></view>
      </view>
      <view class="bar-value">{{item.value}}</view>
      <view class="bar-label">{{item.label}}</view>
    </view>
  </view>

  <view class="ring-chart" wx:if="{{kind === 'ring'}}">
    <view class="ring-wrap">
      <view class="major-ring" style="background: {{majorGradient}};"></view>
      <view class="ring" style="background: {{ringGradient}};"></view>
      <view class="ring-center">
        <view class="ring-total">{{ringCenterValue}}</view>
        <view class="ring-text">{{ringCenterText}}</view>
        <view class="ring-sub">{{ringCenterSub}}</view>
      </view>
    </view>
    <view class="legend">
      <view wx:for="{{ringLegend}}" wx:key="index" class="legend-item {{item.isMajor ? 'major' : ''}}">
        <view class="dot" style="background: {{item.color}}"></view>
        <view class="label">{{item.name}}</view>
        <view class="value">{{item.value}}%</view>
      </view>
    </view>
  </view>
</view>