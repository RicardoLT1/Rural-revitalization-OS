<view class="approval" bindtap="onTap">
  <view class="row-between">
    <view class="title">{{approval.title}}</view>
    <status-badge text="{{approval.status}}" type="{{statusType}}" size="small" />
  </view>
  <view class="meta">Applicant: {{approval.applicant}} | Amount: {{approval.amount}} wan | {{approval.time}}</view>
  <view class="actions">
    <view class="btn pass" catchtap="onApprove" data-action="pass">Pass</view>
    <view class="btn reject" catchtap="onApprove" data-action="reject">Reject</view>
  </view>
</view>